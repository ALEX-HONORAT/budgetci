<?php

namespace App\Http\Controllers;

use Illuminate\Http\Request;
use App\Models\Income;
use App\Models\Expense;
use App\Models\Profile;
use Illuminate\View\View;
use Illuminate\Support\Facades\DB;
use Carbon\Carbon;

class DashboardController extends Controller
{
    /**
     * AFFICHER LE TABLEAU DE BORD
     * Cette méthode gère l'affichage de la page principale avec :
     * - Les statistiques du mois sélectionné
     * - La liste des dépenses
     * - L'historique des mois
     * - Les conseils d'épargne
     */
    public function index(Request $request): View
    {
        // ==============================================
        // 1. RÉCUPÉRATION DE L'UTILISATEUR CONNECTÉ
        // ==============================================
        $user = $request->user();
        
        // ==============================================
        // 2. GESTION DU MOIS SÉLECTIONNÉ
        // ==============================================
        // Récupérer le mois depuis l'URL (ex: ?month=2026-03)
        // Si aucun mois n'est spécifié, on prend le mois actuel
        $selectedMonth = $request->get('month', Carbon::now()->format('Y-m'));
        
        // Créer un objet Carbon pour manipuler les dates du mois sélectionné
        $monthYear = Carbon::parse($selectedMonth);
        
        // Calculer le premier jour du mois (ex: 2026-03-01 00:00:00)
        $startOfMonth = $monthYear->copy()->startOfMonth();
        
        // Calculer le dernier jour du mois (ex: 2026-03-31 23:59:59)
        $endOfMonth = $monthYear->copy()->endOfMonth();
        
        // ==============================================
        // 3. CALCUL DES REVENUS ET DÉPENSES DU MOIS
        // ==============================================
        
        // Total des revenus pour le mois sélectionné
        $totalIncomes = Income::where('user_id', $user->id)
            ->whereBetween('date', [$startOfMonth, $endOfMonth])
            ->sum('amount');

        // Total des dépenses pour le mois sélectionné
        $totalExpenses = Expense::where('user_id', $user->id)
            ->whereBetween('date', [$startOfMonth, $endOfMonth])
            ->sum('amount');

        // ==============================================
        // 4. CALCUL DU SOLDE
        // ==============================================
        // Solde = Revenus - Dépenses
        $balance = $totalIncomes - $totalExpenses;

        // ==============================================
        // 5. GESTION DE L'OBJECTIF D'ÉPARGNE
        // ==============================================
        
        // Récupérer le profil de l'utilisateur
        $profile = Profile::where('user_id', $user->id)->first();
        
        // Pourcentage d'épargne souhaité (par défaut 20% si non défini)
        $savingsGoalPercent = $profile && $profile->savings_goal ? $profile->savings_goal : 20;
        
        // Montant de l'objectif d'épargne (ex: 20% des revenus)
        $savingsGoalAmount = round(($totalIncomes * $savingsGoalPercent) / 100);

        // ==============================================
        // 6. CALCUL DE L'ÉPARGNE RÉELLE
        // ==============================================
        // L'épargne réelle = solde (si positif, sinon 0)
        $savingsActual = $balance > 0 ? $balance : 0;

        // Différence entre épargne réelle et objectif
        $savingsDifference = $savingsActual - $savingsGoalAmount;

        // ==============================================
        // 7. CALCUL DU TAUX D'ÉPARGNE
        // ==============================================
        // Taux = (épargne réelle / revenus) * 100
        $savingsRate = $totalIncomes > 0
            ? round(($savingsActual / $totalIncomes) * 100, 1)
            : 0;

        // ==============================================
        // 8. GESTION DES CONSEILS PERSONNALISÉS
        // ==============================================
        // Affiche un message et une couleur selon le taux d'épargne
        if ($savingsRate >= $savingsGoalPercent) {
            // Excellent : objectif atteint ou dépassé
            $advice = "✅ Excellent ! Objectif atteint.";
            $adviceColor = "green";
        } elseif ($savingsRate >= 10) {
            // Bien : mais peut être amélioré
            $advice = "🟡 Bien, mais peut mieux faire.";
            $adviceColor = "orange";
        } else {
            // Attention : épargne trop faible
            $advice = "🔴 Attention, épargne trop faible.";
            $adviceColor = "red";
        }

        // ==============================================
        // 9. LISTE DES DÉPENSES DU MOIS
        // ==============================================
        // Récupérer toutes les dépenses du mois sélectionné
        // Triées par date (les plus récentes d'abord)
        $recentExpenses = Expense::where('user_id', $user->id)
            ->whereBetween('date', [$startOfMonth, $endOfMonth])
            ->orderBy('date', 'desc')
            ->get();

        // ==============================================
        // 10. HISTORIQUE DES MOIS DISPONIBLES
        // ==============================================
        // On récupère tous les mois qui contiennent au moins un revenu OU une dépense
        
        // Mois avec des revenus
        $moisAvecRevenus = DB::table('incomes')
            ->selectRaw('DATE_FORMAT(date, "%Y-%m") as month')
            ->where('user_id', $user->id)
            ->groupBy('month')
            ->havingRaw('SUM(amount) > 0')  // On ignore les mois avec des revenus à 0
            ->pluck('month')
            ->toArray();
        
        // Mois avec des dépenses
        $moisAvecDepenses = DB::table('expenses')
            ->selectRaw('DATE_FORMAT(date, "%Y-%m") as month')
            ->where('user_id', $user->id)
            ->groupBy('month')
            ->havingRaw('SUM(amount) > 0')  // On ignore les mois avec des dépenses à 0
            ->pluck('month')
            ->toArray();
        
        // Fusionner les deux listes et supprimer les doublons
        $tousLesMois = array_unique(array_merge($moisAvecRevenus, $moisAvecDepenses));
        
        // Trier par ordre décroissant (le plus récent en premier)
        rsort($tousLesMois);
        
        // Convertir en collection Laravel pour faciliter l'utilisation dans la vue
        $availableMonths = collect($tousLesMois);

        // ==============================================
        // 11. ENVOI DES DONNÉES À LA VUE
        // ==============================================
        return view('dashboard', compact(
            'totalIncomes',        // Total des revenus du mois
            'totalExpenses',       // Total des dépenses du mois
            'balance',             // Solde (revenus - dépenses)
            'savingsGoalPercent',  // Pourcentage d'épargne objectif
            'savingsGoalAmount',   // Montant objectif d'épargne
            'savingsActual',       // Épargne réellement mise de côté
            'savingsDifference',   // Différence entre réel et objectif
            'savingsRate',         // Taux d'épargne réel en pourcentage
            'advice',              // Message de conseil personnalisé
            'adviceColor',         // Couleur du conseil (green/orange/red)
            'recentExpenses',      // Liste des dépenses du mois
            'selectedMonth',       // Mois actuellement sélectionné
            'availableMonths'      // Liste des mois disponibles dans l'historique
        ));
    }

    /**
     * SUPPRIMER UN MOIS COMPLET (REVENUS + DÉPENSES)
     * Ou supprimer TOUS les mois de l'utilisateur
     * 
     * @param Request $request
     * @return \Illuminate\Http\RedirectResponse
     */
    public function destroyMonthComplete(Request $request)
    {
        // ==============================================
        // 1. RÉCUPÉRATION DE L'UTILISATEUR
        // ==============================================
        $user = $request->user();
        
        // ==============================================
        // 2. RÉCUPÉRATION DU MOIS À SUPPRIMER
        // ==============================================
        // Le mois peut être "all" (tous les mois) ou une date comme "2026-03"
        $moisASupprimer = $request->input('month');
        
        // ==============================================
        // 3. CAS 1 : SUPPRIMER TOUS LES MOIS
        // ==============================================
        if ($moisASupprimer === 'all') {
            // Supprimer tous les revenus de l'utilisateur
            $revenusSupprimes = Income::where('user_id', $user->id)->delete();
            
            // Supprimer toutes les dépenses de l'utilisateur
            $depensesSupprimees = Expense::where('user_id', $user->id)->delete();
            
            // Rediriger vers le tableau de bord avec un message de confirmation
            return redirect()->route('dashboard')
                ->with('success', "Toutes vos données ont été supprimées. ($revenusSupprimes revenus, $depensesSupprimees dépenses)");
        }
        
        // ==============================================
        // 4. CAS 2 : SUPPRIMER UN MOIS SPÉCIFIQUE
        // ==============================================
        
        // Calculer le premier jour du mois à 00:00:00
        $debutMois = Carbon::parse($moisASupprimer . '-01')->startOfDay();
        
        // Calculer le dernier jour du mois à 23:59:59
        $finMois = Carbon::parse($moisASupprimer . '-01')->endOfMonth()->endOfDay();
        
        // Supprimer tous les revenus de ce mois
        $revenusSupprimes = Income::where('user_id', $user->id)
            ->whereBetween('date', [$debutMois, $finMois])
            ->delete();
        
        // Supprimer toutes les dépenses de ce mois
        $depensesSupprimees = Expense::where('user_id', $user->id)
            ->whereBetween('date', [$debutMois, $finMois])
            ->delete();
        
        // Calculer le total d'éléments supprimés
        $totalSupprime = $revenusSupprimes + $depensesSupprimees;
        
        // Formater le nom du mois en français (ex: "mars 2026")
        $nomMois = Carbon::parse($moisASupprimer)->translatedFormat('F Y');
        
        // Rediriger vers le tableau de bord avec un message de confirmation
        return redirect()->route('dashboard')
            ->with('success', "Mois de $nomMois supprimé avec succès. ($totalSupprime éléments effacés)");
    }
}
